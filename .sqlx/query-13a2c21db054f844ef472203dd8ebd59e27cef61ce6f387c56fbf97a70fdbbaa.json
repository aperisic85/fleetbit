{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT DISTINCT ON (vp.mmsi)\n            vp.mmsi,\n            v.name,\n            vp.lat,\n            vp.lon,\n            vp.sog,\n            vp.cog,\n            vp.heading,\n            vp.nav_status,\n            vp.time as last_seen\n        FROM vessel_positions vp\n        LEFT JOIN vessels v ON v.mmsi = vp.mmsi\n        ORDER BY vp.mmsi, vp.time DESC\n        ",
